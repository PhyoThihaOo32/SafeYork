{
  "expo": {
    "name": "SafeYork",
    "slug": "safeyork",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "safeyork",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SafeYork uses location only in Demo Mode to show how emergency location sharing would work."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#07111f"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "router": {}
    }
  }
}
